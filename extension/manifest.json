{
  "manifest_version": 3,
  "name": "Gmail Phishing Detector",
  "version": "1.1.0",
  "description": "Chrome extension backed by FastAPI for detecting phishing emails in Gmail",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://mail.google.com/*"
  ],
  "action": {
    "default_title": "Gmail Phishing Detector",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
